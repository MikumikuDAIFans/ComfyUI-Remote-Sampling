# Copy this file to .env or export these variables in your shell.
# The defaults in code are the original development environment; replace them
# with your local ComfyUI and remote server layout.

REMOTE_SAMPLING_PROJECT_ROOT=F:\path\to\Remote_comfyui
REMOTE_SAMPLING_BRIDGE_PYTHON=C:\path\to\python.exe

# Compatible helper script that exposes the same functions used by the tools:
# free_port(), open_tunnel(), SERVER_USER and SERVER_PASSWORD.
REMOTE_SAMPLING_SERVER_EXEC=C:\path\to\server_exec.py

REMOTE_SAMPLING_REMOTE_BASE=/home/user/remote_ComfyUI
REMOTE_SAMPLING_REMOTE_PYTHON=/home/user/remote_ComfyUI/.venv/bin/python
REMOTE_SAMPLING_REMOTE_PORT=8197
REMOTE_SAMPLING_TMUX_SESSION=remote-comfyui-8197
REMOTE_SAMPLING_REMOTE_JOB_ROOT=/home/user/remote_ComfyUI/jobs

REMOTE_SAMPLING_LOCAL_COMFY_ROOT=F:\path\to\ComfyUI
REMOTE_SAMPLING_LOCAL_COMFY_MODELS=F:\path\to\ComfyUI\models
REMOTE_SAMPLING_LOCAL_LORA_ROOT=F:\path\to\ComfyUI\models\loras
